# ============================================================
# Configuración del Lab — AWS VPC Public/Private Subnets
# ============================================================
# Copia este archivo como config.env y completa los valores
# antes de ejecutar los scripts:
#   cp config.env.example config.env
# ============================================================

# Región de AWS
AWS_REGION="us-east-1"

# Nombre de tu Key Pair en AWS (sin .pem)
KEY_NAME="team01-key"

# Ruta local a tu archivo .pem
KEY_PATH="~/.ssh/team01-key.pem"

# CIDRs de red
VPC_CIDR="10.0.0.0/16"
PUBLIC_SUBNET_CIDR="10.0.1.0/24"
PRIVATE_SUBNET_CIDR="10.0.2.0/24"

# Availability Zone
AZ="us-east-1a"

# AMI — Amazon Linux 2023 en us-east-1
# Verifica el ID actualizado en: https://aws.amazon.com/amazon-linux-2/release-notes/
AMI_ID="ami-0c02fb55956c7d316"

# Tipo de instancia
INSTANCE_TYPE="t2.micro"
